# URL del backend API
API_ENDPOINT_CONSULTA_CURSO=https://your-api-gateway.execute-api.region.amazonaws.com/test/CursosSearch/GetCursosBySearch
API_ENDPOINT_CBO_FACULTADES=https://your-api-gateway.execute-api.region.amazonaws.com/test/Filter/GetFaculties
API_ENDPOINT_CBO_CARRERA_POR_FACULTAD=https://your-api-gateway.execute-api.region.amazonaws.com/test/Filter/GetCareers
API_ENDPOINT_PERIOD_DETAILS=https://your-api-gateway.execute-api.region.amazonaws.com/dev/GetDetailsPeriod

# Cognito OAuth - Flujo client-side (react-oidc-context)
# NEXT_PUBLIC_* son accesibles en el cliente
# Authority (cognito-idp, para JWKS y validación)
NEXT_PUBLIC_COGNITO_AUTHORITY=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_5NFVad9y3
# Dominio del Hosted UI
NEXT_PUBLIC_COGNITO_DOMAIN=https://us-east-25nfvad9y3.auth.us-east-2.amazoncognito.com
# Client ID del App Client en Cognito
NEXT_PUBLIC_COGNITO_CLIENT_ID=7km1um8kbof3n7n0t7capvjupg
# Redirect URI - debe coincidir con la config en Cognito
NEXT_PUBLIC_COGNITO_REDIRECT_URI=https://web-catalog-upc-v1.vercel.app/
# Logout URI - redirección tras cerrar sesión
NEXT_PUBLIC_COGNITO_LOGOUT_URI=https://web-catalog-upc-v1.vercel.app/

# API routes (server-side, sin NEXT_PUBLIC)
COGNITO_DOMAIN=https://<domain-prefix>.auth.<region>.amazoncognito.com
COGNITO_CLIENT_ID=<your-client-id>
COGNITO_REDIRECT_URI=http://localhost:3000/
COGNITO_CLIENT_SECRET=
