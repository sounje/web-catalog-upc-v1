# URL del backend API


# Cognito OAuth - Flujo server-side (solo validación de sesión)
# El login está en otro proyecto; este solo valida code y cookie
COGNITO_DOMAIN=https://<domain-prefix>.auth.<region>.amazoncognito.com
COGNITO_CLIENT_ID=<your-client-id>
# Debe coincidir con redirect_uri de la URL de autorización
COGNITO_REDIRECT_URI=http://localhost:3000/
COGNITO_CLIENT_SECRET=
# Redirección cuando no hay sesión (proyecto de login)
AUTH_REDIRECT_UNAUTHORIZED=http://localhost:3001/
