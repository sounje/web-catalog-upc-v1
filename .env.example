# URL del backend API
API_ENDPOINT_CONSULTA_CURSO=https://your-api-gateway.execute-api.region.amazonaws.com/test/CursosSearch/GetCursosBySearch
API_ENDPOINT_CBO_FACULTADES=https://your-api-gateway.execute-api.region.amazonaws.com/test/Filter/GetFaculties
API_ENDPOINT_CBO_CARRERA_POR_FACULTAD=https://your-api-gateway.execute-api.region.amazonaws.com/test/Filter/GetCareers
API_ENDPOINT_PERIOD_DETAILS=https://your-api-gateway.execute-api.region.amazonaws.com/dev/GetDetailsPeriod

# Cognito OAuth - Validación de sesión
# Dominio del Hosted UI (ej: https://xxx.auth.us-east-2.amazoncognito.com)
COGNITO_DOMAIN=https://<domain-prefix>.auth.<region>.amazoncognito.com
# Client ID del App Client en Cognito
COGNITO_CLIENT_ID=<your-client-id>
# Debe coincidir exactamente con el redirect_uri usado en la URL de autorización
# Local: http://localhost:3000/
# Producción: https://web-catalog-upc-v1.vercel.app/
COGNITO_REDIRECT_URI=http://localhost:3000/
# Solo si el App Client tiene secret configurado (clientes confidenciales)
COGNITO_CLIENT_SECRET=
# URL de redirección cuando no hay sesión válida (ej: proyectoLoginTest)
AUTH_REDIRECT_UNAUTHORIZED=http://localhost:3001/
